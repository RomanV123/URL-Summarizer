# URL Summarizer — environment variables
#
# Copy this file to .env on each machine and fill in real values.
# .env is git-ignored and must NEVER be committed.

# --- Poppy (preferred backend — Open WebUI compatible) ---
# Set these to route requests through CARB's Poppy instance.
# Requires the state network (on-site at CARB or VPN'd in).
POPPY_API_KEY=your_poppy_key_here
POPPY_BASE_URL=https://customeruat.sda.state.ca.gov/api
POPPY_MODEL=Azure gpt-4.1

# --- OpenAI fallback ---
# Used only when POPPY_BASE_URL is not set above.
# Useful for development on machines without state network access.
OPENAI_API_KEY=your_openai_key_here
